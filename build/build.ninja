build deploy/CMakeFiles/package_source.util: CUSTOM_COMMAND
  COMMAND = cd /home/hdd25/.deskflow/deskflow-deepin/build && /usr/bin/cpack --config ./CPackSourceConfig.cmake /home/hdd25/.deskflow/deskflow-deepin/build/CPackSourceConfig.cmake
